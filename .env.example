# ──────────────────────────────────────────────
# RealtorAI - Environment Variables
# Copy this file to .env.local and fill in real values.
# ──────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# Project URL from your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
# Public anon key (safe for the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key (server-side only, never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Redis / Upstash ──────────────────────────
# Option A: Upstash REST (serverless, recommended for Vercel)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
# Option B: Standard Redis (for BullMQ workers)
REDIS_URL=redis://localhost:6379

# ── Anthropic AI ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Set to "false" to disable AI features and use rule-based fallbacks
AI_ENABLED=true
# Override default model for each tier (optional)
# AI_MODEL_FAST=claude-haiku-4-20250514
# AI_MODEL_STANDARD=claude-sonnet-4-20250514
# AI_MODEL_PREMIUM=claude-opus-4-20250514
# AI_MODEL_FALLBACK=claude-haiku-4-20250514

# System-wide monthly AI spend ceiling in cents (0 = disabled)
# AI_SYSTEM_MONTHLY_CEILING_CENTS=50000
# Admin email for system ceiling breach alerts
# AI_SYSTEM_ADMIN_EMAIL=admin@example.com

# ── Resend (transactional email) ──────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@realtorai.com
